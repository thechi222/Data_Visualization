# 2. 資料準備
# 手動選擇 CSV 檔案
file_path <- file.choose()
df <- read_csv(file_path, col_types = cols())
# 移除 Ozone 或 Temp 為缺失值 (NA) 的觀測值
df_clean <- na.omit(df[, c("Ozone", "Solar.R", "Wind", "Temp", "Month", "Day")])
# 將 Month 轉換為因子 (Factor)，確保動畫按月份順序播放
df_clean$Month <- as.factor(df_clean$Month)
# 3. 建立動態氣泡圖
p <- ggplot(df_clean, aes(
x     = Temp,           # X 軸：氣溫
y     = Ozone,          # Y 軸：臭氧濃度
size  = Solar.R,       # 點大小：太陽輻射
color = Month           # 顏色：月份
)) +
geom_point(alpha = 0.6) + # 設定透明度
scale_size(range = c(2, 12)) + # 調整氣泡大小範圍
labs(
title = "紐約市氣溫與臭氧濃度關係動態圖",
subtitle = "月份: {closest_state} 月", # 動態顯示目前月份
x = "氣溫 (華氏度 °F)",
y = "臭氧濃度 (ppb)",
size = "太陽輻射 (Langley)",
color = "月份"
) +
theme_minimal() +
# 月份浮水印（右下角灰色大字，顯示月份數字）
geom_text(
aes(x = Inf, y = -Inf, label = as.character(Month)),
hjust       = 1.5,
vjust       = -0.5,
size        = 30,
color       = "gray85",
fontface    = "bold",
inherit.aes = FALSE
) +
# 設定動態轉場：以月份為狀態，每個月份停留 1.5 秒
transition_states(
Month,
transition_length = 1, # 設定月份之間的轉場平滑度
state_length      = 1.5  # 每個月份停頓時間 (秒)
) +
enter_fade() + # 進入時漸淡
exit_fade()    # 離開時漸淡
# 4. 輸出與儲存為 GIF
# 計算總幀數：5 個月份 * (每秒幀數 * 1.5 秒停留 + 轉場幀數)
# 這裡簡單設定 nframes 以確保流暢
animate(
p,
nframes  = 100,
fps      = 10,  # 每秒 10 幀，配合 state_length 達成停留約 1.5 秒
width    = 800,
height   = 600,
renderer = gifski_renderer("air_quality_animation.gif")
)
cat("\n✅ 分析完成！動畫已儲存為 'air_quality_animation.gif'。\n")
# =============================================
# 資料科學自我效能感 - 相關矩陣熱力圖分析
# =============================================
# 1. 安裝與載入必要套件
if (!require("corrplot")) install.packages("corrplot")
if (!require("psych")) install.packages("psych")
if (!require("readr")) install.packages("readr")
library(corrplot)
library(psych)
library(readr)
# 2. 讀取資料（手動選擇 CSV 檔案）
file_path <- file.choose()  # 彈出視窗選擇檔案
data <- read_csv(file_path, show_col_types = FALSE)
# 只保留數值型能力評分欄位（排除 group 與 id）
numeric_cols <- sapply(data, is.numeric)
data_numeric <- data[, numeric_cols]
data_numeric <- data_numeric[, !names(data_numeric) %in% c("group", "id")]  # 確保排除
cat("資料維度：", nrow(data_numeric), "位學員 ×", ncol(data_numeric), "個能力維度\n")
# 3. 計算 Pearson 相關係數與 p-value
cor_result <- corr.test(data_numeric, method = "pearson")
r <- cor_result$r      # 相關係數矩陣
p <- cor_result$p      # p-value 矩陣
# 4. 輸出相關矩陣摘要（方便查看）
print("相關係數矩陣（四捨五入到小數點後兩位）：")
print(round(r, 2))
# 5. 繪製並儲存高解析度相關熱力圖
png(filename = "correlation_matrix.png",
width = 12, height = 10, units = "in", res = 300)
# 上三角：色塊 + 顯著性標記
corrplot(r,
method = "color",
type = "upper",
col = rev(colorRampPalette(c("#67001F", "#B2182B", "#FDDBC7", "#FFFFFF", "#D1E5F0", "#2166AC", "#053061"))(200)),
tl.cex = 1.1,           # 標籤大小
tl.col = "black",
tl.srt = 45,            # 標籤旋轉角度
tl.pos = "lt",
p.mat = p,
sig.level = c(0.001, 0.01, 0.05),
insig = "label_sig",    # 不顯著處標 *
pch.cex = 1.0,
pch.col = "black",
addCoef.col = NULL)
# 下三角：數字
corrplot(r,
method = "number",
type = "lower",
col = rev(colorRampPalette(c("#67001F", "#B2182B", "#FDDBC7", "#FFFFFF", "#D1E5F0", "#2166AC", "#053061"))(200)),
tl.pos = "n",
cl.pos = "n",
number.cex = 0.8,       # 數字大小
add = TRUE)
title("資料科學能力自我效能相關矩陣熱力圖\n(上三角:色塊 + 顯著性 / 下三角:相關係數)",
cex.main = 1.2, line = 2.5)
dev.off()
cat("✅ 熱力圖已儲存為：correlation_matrix.png\n")
# 6. 在 RStudio / R 繪圖區預覽（與儲存檔案相同）
corrplot(r, method = "color", type = "upper",
col = rev(colorRampPalette(c("#67001F", "#B2182B", "#FDDBC7", "#FFFFFF", "#D1E5F0", "#2166AC", "#053061"))(200)),
tl.cex = 1.1, tl.col = "black", tl.srt = 45, tl.pos = "lt",
p.mat = p, sig.level = c(0.001, 0.01, 0.05), insig = "label_sig", pch.cex = 1.0)
corrplot(r, method = "number", type = "lower",
col = rev(colorRampPalette(c("#67001F", "#B2182B", "#FDDBC7", "#FFFFFF", "#D1E5F0", "#2166AC", "#053061"))(200)),
tl.pos = "n", cl.pos = "n", number.cex = 0.8, add = TRUE)
# =============================================
# 資料科學自我效能感 - 相關矩陣熱力圖分析（優化版）
# =============================================
# 1. 安裝與載入必要套件
if (!require("corrplot")) install.packages("corrplot")
if (!require("psych"))    install.packages("psych")
if (!require("readr"))    install.packages("readr")
library(corrplot)
library(psych)
library(readr)
# =============================================
# 2. 讀取資料
# =============================================
file_path <- file.choose()
data <- read_csv(file_path, show_col_types = FALSE)
# 排除非能力欄位
data_numeric <- data[, !names(data) %in% c("group", "id")]
data_numeric  <- data_numeric[, sapply(data_numeric, is.numeric)]
cat("✅ 資料讀取成功：", nrow(data_numeric), "位學員 ×",
ncol(data_numeric), "個能力維度\n\n")
# =============================================
# 3. 描述性統計（新增）
# =============================================
cat("=== 基本描述性統計 ===\n")
desc <- describe(data_numeric)
print(round(desc[, c("mean", "sd", "min", "max", "skew")], 2))
# =============================================
# 4. 計算 Pearson 相關係數與 p-value
# =============================================
cor_result <- corr.test(data_numeric, method = "pearson")
r <- cor_result$r   # 相關係數矩陣（未校正）
p <- cor_result$p   # p-value 矩陣（未校正）
cat("\n=== 相關係數矩陣（四捨五入至小數點後兩位）===\n")
print(round(r, 2))
# =============================================
# 5. 自動列出高相關配對（新增）
# =============================================
cat("\n=== 高相關配對（r > 0.7）===\n")
high_cor <- which(abs(r) > 0.7 & r != 1, arr.ind = TRUE)
for (i in seq_len(nrow(high_cor))) {
ri <- high_cor[i, 1]
ci <- high_cor[i, 2]
if (ri > ci) {   # 只取下三角，避免重複輸出
cat(sprintf("  %-30s ↔ %-30s : r = %.2f\n",
rownames(r)[ri], colnames(r)[ci], r[ri, ci]))
}
}
# =============================================
# 6. 定義顏色（修正，直覺寫法：藍→白→紅）
# =============================================
my_col <- colorRampPalette(
c("#053061", "#2166AC", "#D1E5F0",
"#FFFFFF",
"#FDDBC7", "#B2182B", "#67001F")
)(200)
# =============================================
# 7. 繪圖函式（避免重複程式碼，新增）
# =============================================
draw_corrplot <- function() {
# 上三角：色塊 + 顯著性標記（*** / ** / *）
corrplot(r,
method   = "color",
type     = "upper",
col      = my_col,
tl.cex   = 1.1,
tl.col   = "black",
tl.srt   = 45,
tl.pos   = "lt",
p.mat    = p,
sig.level   = c(0.001, 0.01, 0.05),
insig       = "label_sig",
pch.cex     = 1.0,
pch.col     = "black",
addCoef.col = NULL)
# 下三角：數字
corrplot(r,
method     = "number",
type       = "lower",
col        = my_col,
tl.pos     = "n",
cl.pos     = "n",
number.cex = 0.8,
add        = TRUE)
# 標題（改為英文，適合學術用途）
title(
"Correlation Heatmap of Data Science Self-Efficacy\n(Upper: Color Blocks + Significance | Lower: Coefficients)",
cex.main = 1.15,
line     = 2.5
)
}
# =============================================
# 8. 儲存高解析度 PNG（路徑與 CSV 同資料夾）
# =============================================
output_path <- file.path(dirname(file_path), "correlation_matrix.png")
png(filename = output_path,
width    = 12,
height   = 10,
units    = "in",
res      = 300)
draw_corrplot()
dev.off()
cat(sprintf("\n✅ 熱力圖已儲存至：%s\n", output_path))
# =============================================
# 9. 在 RStudio 繪圖區預覽
# =============================================
draw_corrplot()
# =============================================
# 資料科學自我效能感 - 相關矩陣熱力圖分析（優化版 v2）
# =============================================
# 1. 安裝與載入必要套件
if (!require("corrplot")) install.packages("corrplot")
if (!require("psych"))    install.packages("psych")
if (!require("readr"))    install.packages("readr")
library(corrplot)
library(psych)
library(readr)
# =============================================
# 2. 讀取資料
# =============================================
file_path <- file.choose()
data <- read_csv(file_path, show_col_types = FALSE)
# 排除非能力欄位
data_numeric <- data[, !names(data) %in% c("group", "id")]
data_numeric  <- data_numeric[, sapply(data_numeric, is.numeric)]
cat("✅ 資料讀取成功：", nrow(data_numeric), "位學員 ×",
ncol(data_numeric), "個能力維度\n\n")
# =============================================
# 3. 描述性統計
# =============================================
cat("=== 基本描述性統計 ===\n")
desc <- describe(data_numeric)
print(round(desc[, c("mean", "sd", "min", "max", "skew")], 2))
# =============================================
# 4. 計算 Pearson 相關係數與 p-value
# =============================================
cor_result <- corr.test(data_numeric, method = "pearson")
r <- cor_result$r   # 相關係數矩陣（未校正）
p <- cor_result$p   # p-value 矩陣（未校正）
cat("\n=== 相關係數矩陣（四捨五入至小數點後兩位）===\n")
print(round(r, 2))
# =============================================
# 5. 自動列出高相關配對
# =============================================
cat("\n=== 高相關配對（r > 0.7）===\n")
high_cor <- which(abs(r) > 0.7 & r != 1, arr.ind = TRUE)
for (i in seq_len(nrow(high_cor))) {
ri <- high_cor[i, 1]
ci <- high_cor[i, 2]
if (ri > ci) {
cat(sprintf("  %-30s ↔ %-30s : r = %.2f\n",
rownames(r)[ri], colnames(r)[ci], r[ri, ci]))
}
}
# =============================================
# 6. 定義顏色（藍→白→紅，正相關=紅）
# =============================================
my_col <- colorRampPalette(
c("#053061", "#2166AC", "#D1E5F0",
"#FFFFFF",
"#FDDBC7", "#B2182B", "#67001F")
)(200)
# =============================================
# 7. 繪圖函式
# =============================================
draw_corrplot <- function() {
# ✅ 修改：增加上方邊距，防止標題被裁切
par(mar = c(2, 2, 5, 2))
# 上三角：色塊 + 顯著性標記
corrplot(r,
method      = "color",
type        = "upper",
col         = my_col,
tl.cex      = 1.1,
tl.col      = "black",
tl.srt      = 45,
tl.pos      = "lt",
p.mat       = p,
sig.level   = c(0.001, 0.01, 0.05),
insig       = "label_sig",
pch.cex     = 1.0,
pch.col     = "black",
addCoef.col = NULL)
# 下三角：數字
corrplot(r,
method     = "number",
type       = "lower",
col        = my_col,
tl.pos     = "n",
cl.pos     = "n",
number.cex = 0.8,
add        = TRUE)
# ✅ 修改：line 從 2.5 降為 1.5，標題不會超出畫布
title(
"Correlation Heatmap of Data Science Self-Efficacy\n(Upper: Color Blocks + Significance | Lower: Coefficients)",
cex.main = 1.15,
line     = 1.5
)
}
# =============================================
# 8. 儲存高解析度 PNG
# =============================================
output_path <- file.path(dirname(file_path), "correlation_matrix.png")
# ✅ 修改：height 從 10 增加為 11，畫布更高避免裁切
png(filename = output_path,
width    = 12,
height   = 11,
units    = "in",
res      = 300)
draw_corrplot()
dev.off()
cat(sprintf("\n✅ 熱力圖已儲存至：%s\n", output_path))
# =============================================
# 9. 在 RStudio 繪圖區預覽
# =============================================
draw_corrplot()
